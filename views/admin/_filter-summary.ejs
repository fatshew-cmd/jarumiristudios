<%
  function statusLink(s) {
    let next;
    if (s === 'all') {
      next = 'all';
    } else {
      let cur = statusParam === 'all' ? [] : statusParam.split(',').filter(Boolean);
      cur = cur.includes(s) ? cur.filter(x => x !== s) : [...cur, s];
      next = cur.length ? cur.join(',') : 'all';
    }
    const params = new URLSearchParams();
    if (archivedView) params.set('view', 'archived');
    if (q) params.set('q', q);
    if (field !== 'all') params.set('field', field);
    if (next !== 'all') params.set('status', next);
    if (dateFrom) params.set('dateFrom', dateFrom);
    if (dateTo) params.set('dateTo', dateTo);
    const qs = params.toString();
    return '/admin' + (qs ? '?' + qs : '');
  }
  const selectedStatuses = statusParam === 'all' ? ['all'] : statusParam.split(',').filter(Boolean);
  const statusFilterOptions = [
    { value: 'pending',   label: 'Pending' },
    { value: 'in-review', label: 'In-review' },
    { value: 'accepted',  label: 'Accepted' },
    { value: 'declined',  label: 'Declined' },
  ];
  const statusFilterLabel = selectedStatuses.includes('all')
    ? 'All'
    : selectedStatuses.length === 1
    ? (statusFilterOptions.find(o => o.value === selectedStatuses[0]) || {}).label || 'All'
    : selectedStatuses.length + ' selected';
%>
<% if (!locals.completedView) { %>
<div class="relative shrink-0" id="status-filter-dropdown">
  <button type="button" id="status-filter-btn" onclick="toggleStatusFilterDropdown()"
    class="flex items-center gap-2 bg-white/[0.04] border border-white/10 rounded-md px-4 py-2 text-xs font-semibold text-gray-300 hover:border-white/20 hover:text-white transition-colors whitespace-nowrap">
    <span id="status-filter-label"><%= statusFilterLabel %></span>
    <svg id="status-filter-chevron" class="w-3.5 h-3.5 text-gray-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
  </button>
  <div id="status-filter-menu"
    class="hidden absolute right-0 top-full mt-1.5 z-50 min-w-[170px] bg-[#111] border border-white/10 rounded-md overflow-hidden shadow-xl">
    <a href="<%= statusLink('all') %>"
      class="filter-btn flex items-center gap-2 px-4 py-2.5 text-sm <%= selectedStatuses.includes('all') ? 'text-white' : 'text-gray-400' %> hover:bg-white/[0.05] hover:text-white transition-colors">
      <iconify-icon icon="material-symbols-light:check" width="16" height="16" class="<%= selectedStatuses.includes('all') ? '' : 'invisible' %>"></iconify-icon>
      All
    </a>
    <% statusFilterOptions.forEach(opt => { %>
    <a href="<%= statusLink(opt.value) %>"
      class="filter-btn flex items-center gap-2 px-4 py-2.5 text-sm <%= selectedStatuses.includes(opt.value) ? 'text-white' : 'text-gray-400' %> hover:bg-white/[0.05] hover:text-white transition-colors">
      <iconify-icon icon="material-symbols-light:check" width="16" height="16" class="<%= selectedStatuses.includes(opt.value) ? '' : 'invisible' %>"></iconify-icon>
      <%= opt.label %>
    </a>
    <% }) %>
  </div>
</div>
<% } %>
